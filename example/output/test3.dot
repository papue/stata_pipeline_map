digraph pipeline {
  rankdir=LR;
  graph [pad=0.2, nodesep=0.35, ranksep=0.6, splines=true];
  node [fontsize=10];
  edge [fontsize=9];
  subgraph "cluster_001" {
    label=".";
    style="rounded";
    "master.do" [shape=box, style="rounded,filled", margin="0.10,0.06", fillcolor="#EEF3FF", label="master"];
  }
  subgraph "cluster_002" {
    label="01_data/02_scripts";
    style="rounded";
    "01_data/01_input/demographics.csv" [shape=ellipse, label="01_input/demographics"];
    "01_data/01_input/households.csv" [shape=ellipse, label="01_input/households"];
    "01_data/01_input/policy_flags.dta" [shape=ellipse, label="01_input/policy_flags"];
