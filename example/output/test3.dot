  subgraph "cluster_004" {
    label="03_robustness/02_scripts";
    style="rounded";
    "03_robustness/02_scripts/00_run_robustness.do" [shape=box, style="rounded,filled", margin="0.10,0.06", fillcolor="#EEF3FF", label="02_scripts/00_run_robustness"];
