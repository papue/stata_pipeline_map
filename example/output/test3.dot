    "03_robustness/03_outputs/placebo_summary.csv" [shape=ellipse, style="filled", fillcolor="#FFF3D6", label="03_outputs/placebo_summary"];
    "03_robustness/03_outputs/robust_sample.dta" [shape=ellipse, label="03_outputs/robust_sample"];
  }
