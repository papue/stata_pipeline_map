digraph pipeline {
  rankdir=LR;
  graph [pad=0.2, nodesep=0.35, ranksep=0.6, splines=true, newrank=true];
  node [fontsize=10];
  edge [fontsize=9];
  subgraph "cluster_prep_stage" {
    label=<<font point-size="11"><b>Prep stage</b></font>>;
    style="rounded";
    color="#4A5568";
    penwidth=2.0;
    "01_data/01_input/source.csv" [shape=ellipse, label="source.csv"];
    "01_data/02_scripts/01_build.do" [shape=box, style="rounded,filled", margin="0.10,0.06", fillcolor="#EEF3FF", label="01_build.do"];
    "01_data/02_scripts/02_prepare.do" [shape=box, style="rounded,filled", margin="0.10,0.06", fillcolor="#EEF3FF", label="02_prepare.do"];
    "01_data/03_cleaned_data/panel_base.dta" [shape=ellipse, label="panel_base.dta"];
  }
  subgraph "cluster_modeling_stage" {
    label=<<font point-size="11"><b>Modeling stage</b></font>>;
    style="rounded";
    color="#4A5568";
    penwidth=2.0;
    "02_analysis/01_input/specs.dta" [shape=ellipse, label="specs.dta"];
    "02_analysis/02_scripts/01_model.do" [shape=box, style="rounded,filled", margin="0.10,0.06", fillcolor="#EEF3FF", label="01_model.do"];
    "02_analysis/03_outputs/results.csv" [shape=ellipse, style="filled", fillcolor="#FFF3D6", label="results.csv"];
  }
  "01_data/03_cleaned_data/panel_ready.dta" [shape=ellipse, label="panel_ready.dta"];
  "01_data/01_input/source.csv" -> "01_data/02_scripts/01_build.do";
  "01_data/03_cleaned_data/panel_base.dta" -> "01_data/02_scripts/02_prepare.do";
  "01_data/03_cleaned_data/panel_ready.dta" -> "02_analysis/02_scripts/01_model.do";
  "02_analysis/01_input/specs.dta" -> "02_analysis/02_scripts/01_model.do";
  "01_data/02_scripts/01_build.do" -> "01_data/03_cleaned_data/panel_base.dta";
  "01_data/02_scripts/02_prepare.do" -> "01_data/03_cleaned_data/panel_ready.dta";
  "02_analysis/02_scripts/01_model.do" -> "02_analysis/03_outputs/results.csv";
}
